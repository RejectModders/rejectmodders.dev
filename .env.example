# Copy this file to .env.local and fill in your values
# .env.local is gitignored and should NEVER be committed

# YouTube Data API v3
# Used to auto-fetch YouTube channel avatars for friends
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Revalidate Token
# Used to revalidate cached items on all pages or a single page
# Powershell cmd: $token = [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).Guid + (Get-Random -Minimum 100000 -Maximum 999999).ToString())); Write-Output $token
REVALIDATE_SECRET=

